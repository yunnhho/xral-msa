# ── MySQL ──────────────────────────────────────────
MYSQL_ROOT_PASSWORD=rootpassword
AUTH_DB_PASSWORD=auth_secret
TRAIN_DB_PASSWORD=train_secret
PAYMENT_DB_PASSWORD=payment_secret
NOTIFY_DB_PASSWORD=notify_secret

# ── JWT ────────────────────────────────────────────
# 64자 이상 랜덤 문자열. auth-service 와 api-gateway 가 공유.
JWT_SECRET=change_me_to_a_very_long_random_string_at_least_64_chars_long_here
JWT_ACCESS_TTL_MS=1800000
JWT_REFRESH_TTL_MS=1209600000

# ── OAuth2 ─────────────────────────────────────────
KAKAO_CLIENT_ID=your_kakao_client_id
KAKAO_CLIENT_SECRET=your_kakao_client_secret
NAVER_CLIENT_ID=your_naver_client_id
NAVER_CLIENT_SECRET=your_naver_client_secret

# ── Queue HMAC ─────────────────────────────────────
# queue-service 와 train-service 가 공유.
QUEUE_HMAC_SECRET=change_me_queue_hmac_secret_at_least_32_chars

# ── Payment ────────────────────────────────────────
PAYMENT_MOCK_FAIL=false

# ── Eureka ─────────────────────────────────────────
EUREKA_DEFAULT_ZONE=http://discovery-server:8761/eureka/
