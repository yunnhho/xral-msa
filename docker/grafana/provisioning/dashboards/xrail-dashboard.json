{
  "__inputs": [],
  "__requires": [],
  "annotations": { "list": [] },
  "description": "XRail MSA 운영 대시보드",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "id": 1,
      "title": "예약 생성 TPS",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "reqps"
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "rate(xrail_train_reservation_created_total[1m])",
          "legendFormat": "예약 생성/s",
          "refId": "A"
        },
        {
          "expr": "rate(xrail_train_reservation_expired_total[1m])",
          "legendFormat": "예약 만료/s",
          "refId": "B"
        }
      ]
    },
    {
      "id": 2,
      "title": "결제 성공 / 실패",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "reqps" },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "결제 실패/s" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          }
        ]
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "rate(xrail_payment_completed_total[1m])",
          "legendFormat": "결제 성공/s",
          "refId": "A"
        },
        {
          "expr": "rate(xrail_payment_failed_total[1m])",
          "legendFormat": "결제 실패/s",
          "refId": "B"
        }
      ]
    },
    {
      "id": 3,
      "title": "대기열 상태",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "xrail_queue_waiting_size",
          "legendFormat": "대기 인원",
          "refId": "A"
        },
        {
          "expr": "rate(xrail_queue_promotions_total[1m]) * 60",
          "legendFormat": "승급/분",
          "refId": "B"
        }
      ]
    },
    {
      "id": 4,
      "title": "서킷브레이커 상태",
      "type": "stat",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "options": { "CLOSED": { "color": "green", "text": "CLOSED" }, "OPEN": { "color": "red", "text": "OPEN" }, "HALF_OPEN": { "color": "yellow", "text": "HALF_OPEN" } }, "type": "value" }
          ],
          "thresholds": { "mode": "absolute", "steps": [] }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "targets": [
        {
          "expr": "resilience4j_circuitbreaker_state{name=~\".*-cb\"}",
          "legendFormat": "{{name}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "Gateway HTTP 요청 처리율 (서비스별)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "reqps" },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] } },
      "targets": [
        {
          "expr": "sum by (uri) (rate(http_server_requests_seconds_count{job=\"api-gateway\"}[1m]))",
          "legendFormat": "{{uri}}",
          "refId": "A"
        },
        {
          "expr": "sum by (job) (rate(http_server_requests_seconds_count{status=~\"5..\"}[1m]))",
          "legendFormat": "5xx {{job}}",
          "refId": "B"
        }
      ]
    }
  ],
  "refresh": "10s",
  "schemaVersion": 38,
  "tags": ["xrail"],
  "templating": { "list": [] },
  "time": { "from": "now-30m", "to": "now" },
  "timepicker": {},
  "timezone": "Asia/Seoul",
  "title": "XRail MSA 운영 대시보드",
  "uid": "xrail-msa-ops",
  "version": 1
}
